# Supabase configuration (needed for email/password auth and profile features)
NEXT_PUBLIC_SUPABASE_URL=https://eqblefrqxhycjuvjwlem.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ISAee5j1fm0J73kvXybLxg_1vb16TR_
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
